<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Lab07_kontrolka">
	<Style TargetType="{x:Type local:StatusIndicator}">
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type local:StatusIndicator}">
					<StackPanel x:Name="Body" Orientation="Horizontal" Background="Transparent">
						<Ellipse x:Name="Dot" Width="15" Height="15" Margin="5" Stroke="Black"
                                 Fill="{TemplateBinding StatusColor}"/>
						<TextBlock x:Name="Txt" Text="{TemplateBinding Text}" VerticalAlignment="Center"/>
					</StackPanel>

					<ControlTemplate.Triggers>
						<Trigger Property="IsActivated" Value="False">
							<Setter TargetName="Dot" Property="Fill" Value="LightGray"/>
							<Setter TargetName="Body" Property="Opacity" Value="0.5"/>
						</Trigger>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter Property="Cursor" Value="Hand"/>
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
</ResourceDictionary>