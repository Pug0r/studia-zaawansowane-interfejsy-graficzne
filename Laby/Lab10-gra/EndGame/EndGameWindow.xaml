<Window x:Class="Lab10_gra.EndGame.EndGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Game Results" Height="420" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Game Results" Foreground="Black" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

        <ListView Grid.Row="1" ItemsSource="{Binding Results}" BorderThickness="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="#" DisplayMemberBinding="{Binding Rank}" Width="40" />
                    <GridViewColumn Header="Player" DisplayMemberBinding="{Binding Name}" Width="140" />
                    <GridViewColumn Header="Credits" DisplayMemberBinding="{Binding Credits}" Width="80" />
                    <GridViewColumn Header="Owned" DisplayMemberBinding="{Binding OwnedFields}" Width="70" />
                    <GridViewColumn Header="Shipyards" DisplayMemberBinding="{Binding Shipyards}" Width="70" />
                    <GridViewColumn Header="Asteroid" DisplayMemberBinding="{Binding AsteroidMineLevel}" Width="70" />
                </GridView>
            </ListView.View>
        </ListView>

        <Button Grid.Row="2" Content="Exit game" Height="34" Margin="0,12,0,0" HorizontalAlignment="Center" Padding="16,0" Click="ExitGame_Click" />
    </Grid>
</Window>
