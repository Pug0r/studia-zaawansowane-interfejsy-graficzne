<Window x:Class="Lab07_kontrolka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab07_kontrolka"
        xmlns:controls="clr-namespace:Lab07_kontrolka"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <controls:StatusIndicator Text="System działa poprawnie" 
                               StatusColor="Green" 
                               Margin="10"/>

            <controls:StatusIndicator Text="Wykryto błąd krytyczny!" 
                               StatusColor="Red" 
                               Foreground="DarkRed"
                               FontWeight="Bold"
                               Margin="10"/>

            <controls:StatusIndicator Text="Trwa ładowanie danych..." 
                               StatusColor="Orange" 
                               Margin="10"/>

        </StackPanel>
    </Grid>
</Window>
