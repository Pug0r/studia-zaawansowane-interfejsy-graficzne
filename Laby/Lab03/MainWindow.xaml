<Window x:Class="Lab03.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lab 03" Height="500" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/> <!-- this fills the rest of the remaining space-->
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="Wywołaj funkcje" Click="ButtonClick" Width="150" Height="40" Margin="10"/>

        <UniformGrid Grid.Row="1" Columns="3" Rows="2">

            <StackPanel Margin="10">
                <Label x:Name="potega" Content="potega" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="PotegaInputArg1" Text="Argument1" Margin="0,2"/>
                <TextBox x:Name="PotegaInputArg2" Text="Argument2" Margin="0,2"/>
                <TextBox x:Name="PotegaInputArg3" Text="Argument3" Margin="0,2"/>
                <TextBox x:Name="PotegaResult" Text="Wynik..." Foreground="Gray" IsReadOnly="True" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Margin="10">
                <Label x:Name="zapiszWTablicy" Content="zapiszWTablicy" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="zapiszWTablicyArg1" Text="Argument1" Margin="0,2"/>
                <TextBox x:Name="zapiszWTablicyArg2" Text="Argument2" Margin="0,2"/>
                <TextBox Margin="0,2" Visibility="Hidden"/>
                <TextBox x:Name="zapiszWTablicyResult" Text="Wynik..." Foreground="Gray" IsReadOnly="True" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Margin="10">
                <Label x:Name="poleKola" Content="poleKola" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="poleKolaArg1" Text="Argument1" Margin="0,2"/>
                <TextBox Margin="0,2" Visibility="Hidden"/>
                <TextBox Margin="0,2" Visibility="Hidden"/>
                <TextBox x:Name="poleKolaResult" Text="Wynik..." Foreground="Gray" IsReadOnly="True" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Margin="10">
                <TextBlock Text="sumaCyfr" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="sumaCyfrArg1" Text="Argument1" Margin="0,2"/>
                <TextBox Margin="0,2" Visibility="Hidden"/>
                <TextBox Margin="0,2" Visibility="Hidden"/>
                <TextBox x:Name="sumaCyfrResult" Text="Wynik..." Foreground="Gray" IsReadOnly="True" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Margin="10">
                <TextBlock Text="zamienElementy" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="zamienElementyArg1" Text="Argument1" Margin="0,2"/>
                <TextBox x:Name="zamienElementyArg2" Text="Argument2" Margin="0,2"/>
                <TextBox x:Name="zamienElementyArg3" Text="Argument3" Margin="0,2"/>
                <TextBox x:Name="zamienElementyArg4" Text="Argument4" Margin="0,2"/>
                <TextBox x:Name="zamienElementyResult" Text="Wynik..." Foreground="Gray" IsReadOnly="True" TextWrapping="Wrap"/>
            </StackPanel>

        </UniformGrid>
    </Grid>
</Window>
